#!/bin/bash
# Demyx
# https://demyx.sh
set -euo pipefail

DEMYX_UTILITIES_PORT="${DEMYX_UTILITIES_PORT:-2222}"

while true; do
    if nc -vz localhost "$DEMYX_UTILITIES_PORT" >/dev/null 2>&1; then
        # Port is in use, try the next one
        DEMYX_UTILITIES_PORT="$((DEMYX_UTILITIES_PORT+1))"
    else
        # nc could not connect, treat this as a free port
        break
    fi
done

echo "$DEMYX_UTILITIES_PORT"
